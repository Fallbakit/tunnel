# Values are generated when you create a runner in the dashboard.
FALLBAKIT_RUNNER_ID=runner_from_dashboard
FALLBAKIT_RUNNER_API_KEY=rr_from_dashboard
FALLBAKIT_BASE_URL=http://localhost:8080
FALLBAKIT_LOCAL_PROVIDER=ollama
FALLBAKIT_LOCAL_BASE_URL=http://localhost:11434
# For vLLM, use FALLBAKIT_LOCAL_PROVIDER=vllm and FALLBAKIT_LOCAL_BASE_URL=http://localhost:8000.
# FALLBAKIT_LOCAL_API_KEY is optional and is forwarded only from the agent to the local runtime.
FALLBAKIT_LOCAL_API_KEY=
FALLBAKIT_METRICS_ADDR=:9093
